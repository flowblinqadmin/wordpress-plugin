FROM wordpress:cli-php8.3

USER root

# Install system dependencies (Alpine-based image — use apk)
# subversion required by install-wp-tests.sh to checkout WP test library
RUN apk add --no-cache \
    mysql-client \
    curl \
    unzip \
    git \
    bash \
    subversion

# Install Composer
RUN curl -sS https://getcomposer.org/installer | php -- --install-dir=/usr/local/bin --filename=composer

# Create working directories
RUN mkdir -p /app/plugin /app/tests /app/vendor

WORKDIR /app

# Install PHPUnit 10.x via Composer
RUN composer require --dev phpunit/phpunit:^10 --no-interaction --no-progress

# Download WordPress test suite installer
RUN curl -sSo /usr/local/bin/install-wp-tests.sh \
    https://raw.githubusercontent.com/wp-cli/scaffold-command/main/templates/install-wp-tests.sh \
    && chmod +x /usr/local/bin/install-wp-tests.sh

# Copy test files
COPY integration/ /app/tests/integration/
COPY security/ /app/tests/security/
COPY phpunit.xml /app/phpunit.xml

# Entrypoint script
COPY docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]
